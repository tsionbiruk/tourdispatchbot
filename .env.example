# =============================================================================
# tour-dispatch-bot — Environment Variables
# Copy this file to .env and fill in real values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
LOG_LEVEL=info

# How often the scheduler checks for expired offers (milliseconds)
SCHEDULER_POLL_INTERVAL_MS=300000

# -----------------------------------------------------------------------------
# monday.com
# -----------------------------------------------------------------------------
MONDAY_API_TOKEN=

# Board IDs
MONDAY_TOURS_BOARD_ID=
MONDAY_TEAM_MEMBERS_BOARD_ID=

# Existing tour data columns
MONDAY_TOUR_STATUS_COLUMN_ID=
MONDAY_TOUR_START_COLUMN_ID=
MONDAY_TOUR_START_TIME_COLUMN_ID=
MONDAY_TOUR_NAME_COLUMN_ID=
MONDAY_TOUR_ASSIGNED_GUIDE_COLUMN_ID=

# New dispatch control columns on the TOUR board
MONDAY_DISPATCH_TRIGGER_COLUMN_ID=
MONDAY_TOUR_DISPATCH_MODE_COLUMN_ID=
MONDAY_SELECTED_GUIDES_COLUMN_ID=
MONDAY_DISPATCH_STATUS_COLUMN_ID=

MONDAY_TEAM_MEMBER_GUIDED_TOURS_COLUMN_ID=
MONDAY_TEAM_MEMBER_HOSTED_TOURS_COLUMN_ID=
MONDAY_TEAM_MEMBER_SLACK_ID_COLUMN_ID=

# Trigger event type for monday webhook/button flow
MONDAY_DISPATCH_TRIGGER_TYPE=

# -----------------------------------------------------------------------------
# Slack
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Slack channel ID for admin/ops notifications
SLACK_ADMIN_CHANNEL_ID=